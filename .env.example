# Copy to backend/.env (and the GPU pod's env). Do NOT commit a real .env.

# Redis broker — Upstash free tier works (rediss://...).
# Local fallback when running `docker compose up`: redis://localhost:6379/0
REDIS_URL=rediss://default:PASSWORD@HOST.upstash.io:6379

# S3-compatible object storage. Recommended: Cloudflare R2 (free 10GB egress).
# Local fallback: http://localhost:9000 (MinIO from docker-compose).
S3_ENDPOINT=https://ACCOUNT.r2.cloudflarestorage.com
S3_BUCKET=nudorms
S3_ACCESS_KEY=YOUR_R2_ACCESS_KEY_ID
S3_SECRET_KEY=YOUR_R2_SECRET_ACCESS_KEY
S3_REGION=auto

# SQLite is fine while everything is single-tenant + single-process.
# Move to Postgres (e.g. Neon free tier) when you have >1 API instance.
DATABASE_URL=sqlite:///./nudorms.db
